{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/vertexkg/cayu/benchmarks/one-shot/prompt-tool-alignment.schema.json",
  "title": "Cayu prompt/tool alignment evidence",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "agent", "check"],
  "properties": {
    "schema_version": {"const": "1"},
    "agent": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "registered_tool_names", "workflow_tool_names"],
      "properties": {
        "name": {"type": "string", "minLength": 1, "pattern": "\\S"},
        "registered_tool_names": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {"type": "string", "minLength": 1, "pattern": "\\S"}
        },
        "workflow_tool_names": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {"type": "string", "minLength": 1, "pattern": "\\S"}
        }
      }
    },
    "check": {
      "type": "object",
      "additionalProperties": false,
      "required": ["command", "exit_code", "result"],
      "properties": {
        "command": {"const": "cayu check --json"},
        "exit_code": {"const": 0},
        "result": {
          "type": "object",
          "additionalProperties": false,
          "required": ["schema_version", "manifest_fingerprint", "diagnostics"],
          "properties": {
            "schema_version": {"const": "1"},
            "manifest_fingerprint": {
              "type": "string",
              "pattern": "^[0-9a-f]{64}$"
            },
            "diagnostics": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["code"],
                "properties": {
                  "code": {"type": "string", "minLength": 1, "pattern": "\\S"}
                }
              }
            }
          }
        }
      }
    }
  }
}
